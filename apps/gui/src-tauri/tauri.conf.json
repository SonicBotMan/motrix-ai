{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Motrix AI",
  "version": "1.6.1",
  "identifier": "com.motrix-ai.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Motrix AI",
        "width": 1024,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources/bin/*"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet", "ed2k", "thunder"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/SonicBotMan/motrix-ai/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHVwZGF0ZXIga2V5IGZpbGUK"
    }
  }
}
