{
  "name": "@motrix-ai/core",
  "version": "1.4.6",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint src/ --ext .ts",
    "build": "tsup src/index.ts src/browser.ts --format esm --dts --outDir dist --external @opencode-ai/sdk",
    "dev": "tsup src/index.ts src/browser.ts --format esm --dts --outDir dist --watch --external @opencode-ai/sdk",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.18",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
