{
  "name": "@motrix-ai/cli",
  "version": "1.6.1",
  "private": true,
  "type": "module",
  "bin": {
    "motrix-ai": "./dist/index.js"
  },
  "scripts": {
    "lint": "eslint src/ --ext .ts",
    "build": "tsup src/index.ts --format esm --outDir dist",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@motrix-ai/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0"
  }
}
